{
  "name": "restaurante-casa-alianca",
  "private": true,
  "version": "1.0.9",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "tsc && cross-env ELECTRON=true vite build && electron-builder",
    "electron:preview": "cross-env ELECTRON=true vite build && electron ."
  },
  "build": {
    "appId": "com.casaaliana.restaurante",
    "productName": "Casa Alinça Restaurante",
    "files": [
      "dist/**/*",
      "electron/**/*",
      ".env"
    ],
    "asarUnpack": [
      "electron/print-raw.ps1"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "electron/icon.png",
      "artifactName": "RestauranteCasaAliancaSetup.${ext}",
      "signAndEditExecutable": true
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.3",
    "dotenv": "^17.4.0",
    "embla-carousel-react": "^8.0.0",
    "lucide-react": "^0.344.0",
    "qrcode": "^1.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.22.2",
    "vaul": "^1.1.2",
    "zustand": "^4.5.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.20",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.2.57",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.4",
    "wait-on": "^9.0.4"
  }
}
